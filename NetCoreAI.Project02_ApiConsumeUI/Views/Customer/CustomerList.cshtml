@model List<NetCoreAI.Project02_ApiConsumeUI.Dtos.ResultCustomerDto>
@{
    Layout = null;
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<div class="container">
    <br /><br />
    <table class="table table-bordered">
        <tr>
            <th>#</th>
            <th>Müşteri Adı Soyadı</th>
            <th>Bakiye</th>
            <th>Sil</th>
            <th>Güncelle</th>
        </tr>
        @foreach(var item in Model)
        {
            <tr>
                <td>@item.customerID</td>
                <td>@item.customerName @item.customerSurname</td>
                <td>@item.customerBalance</td>
                <td><a href="/Customer/DeleteCustomer/@item.customerID" class="btn btn-outline-danger">Sil</a></td>
                <td><a href="/Customer/UpdateCustomer/@item.customerID" class="btn btn-outline-warning">Güncelle</a></td>
            </tr>
        }
    </table>
    <a href="/Customer/CreateCustomer/" class="btn btn-outline-primary"> + Yeni Müşteri</a>
</div>